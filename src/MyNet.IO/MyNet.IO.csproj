<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Product>My .NET IO</Product>
        <PackageIcon>MyNetIO.png</PackageIcon>
        <Description>File and path helpers, directory extensions, auto-save coordinators, and portable registry abstractions for desktop and cross-platform apps.</Description>
        <PackageTags>mynet io filesystem paths autosave registry</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\MyNet.Primitives\MyNet.Primitives.csproj" />
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Update="Localization\InternalResources.resx">
            <Generator>ResXFileCodeGenerator</Generator>
            <LastGenOutput>InternalResources.Designer.cs</LastGenOutput>
        </EmbeddedResource>

        <EmbeddedResource Update="Localization\InternalResources.en.resx">
            <DependentUpon>InternalResources.resx</DependentUpon>
        </EmbeddedResource>

    </ItemGroup>

    <ItemGroup>
        <Compile Update="Localization\InternalResources.Designer.cs">
            <DesignTime>True</DesignTime>
            <AutoGen>True</AutoGen>
            <DependentUpon>InternalResources.resx</DependentUpon>
        </Compile>
    </ItemGroup>

</Project>

