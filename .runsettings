<?xml version="1.0" encoding="utf-8"?>
<RunSettings>

    <!-- General test run configuration -->
    <RunConfiguration>
        <!-- Disable parallel test execution (set to true only if tests share state) -->
        <DisableParallelization>false</DisableParallelization>

        <!-- Global timeout for the entire test session in milliseconds -->
        <TestSessionTimeout>600000</TestSessionTimeout>

        <!-- Results directory -->
        <ResultsDirectory>TestResults</ResultsDirectory>
    </RunConfiguration>

    <!-- xUnit specific settings -->
    <xUnit>
        <!-- Enable diagnostic messages for troubleshooting -->
        <DiagnosticMessages>true</DiagnosticMessages>
        <!-- Display class and method names in test output -->
        <MethodDisplay>ClassAndMethod</MethodDisplay>
        <!-- Run test collections in parallel -->
        <ParallelizeTestCollections>true</ParallelizeTestCollections>
    </xUnit>

    <!-- Code coverage configuration -->
    <DataCollectionRunSettings>
        <DataCollectors>
            <!-- Using XPlat Code Coverage (Coverlet NuGet package) -->
            <!-- NOTE: Do NOT set the uri attribute here - it belongs to VS built-in coverage, not Coverlet.
                 Matching is done by friendlyName only. -->
            <DataCollector friendlyName="XPlat Code Coverage">
                <Configuration>

                    <!-- Output formats: lcov (GitHub Actions), opencover (ReportGenerator), cobertura (SonarQube/Azure) -->
                    <Format>cobertura</Format>

                    <!-- Exclude unwanted assemblies (comma-separated, Coverlet syntax) -->
                    <Exclude>[*.Tests]*,[*.UnitTests]*,[*.Demos]*,[xunit.*]*,[Microsoft.*]*,[System.*]*</Exclude>

                    <!-- Exclude specific file paths (comma-separated) -->
                    <ExcludeByFile>**/Migrations/**,**/obj/**,**/bin/**</ExcludeByFile>

                    <!-- Exclude classes/methods marked with these attributes (comma-separated) -->
                    <ExcludeByAttribute>Obsolete,GeneratedCodeAttribute,CompilerGeneratedAttribute,ExcludeFromCodeCoverage</ExcludeByAttribute>

                    <!-- Skip auto-implemented properties getters/setters -->
                    <SkipAutoProps>true</SkipAutoProps>

                    <!-- Use SourceLink for source mapping -->
                    <UseSourceLink>true</UseSourceLink>

                    <!-- Count multiple hits per line (false = measure all hits, true = faster) -->
                    <SingleHit>false</SingleHit>

                    <!-- Include test assemblies in coverage (false = exclude them) -->
                    <IncludeTestAssembly>false</IncludeTestAssembly>

                </Configuration>
            </DataCollector>
        </DataCollectors>
    </DataCollectionRunSettings>
</RunSettings>
