<Project>

    <!-- To override -->
    <PropertyGroup>
        <PackageIcon>$(ProductName).png</PackageIcon>
        <Description></Description>
        <PackageTags>mynet dotnet</PackageTags>
    </PropertyGroup>

    <PropertyGroup>

        <!-- NuGet information -->
        <PackageVersion Condition="'$(VersionSuffix)' != ''">$(Version)-$(VersionSuffix)</PackageVersion>
        <PackageVersion Condition="'$(VersionSuffix)' == ''">$(Version)</PackageVersion>
        <PackageOutputPath>$(MSBuildThisFileDirectory)..\packages</PackageOutputPath>
        <PackageProjectUrl>https://github.com/sandre58/MyNet</PackageProjectUrl>
        <PackageReleaseNotes>https://github.com/sandre58/MyNet/releases</PackageReleaseNotes>
        <PackageIconUrl>$(PackageIcon)</PackageIconUrl>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageReadmeFile Condition="Exists('$(MSBuildProjectDirectory)\README.md')">README.md</PackageReadmeFile>
        <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
        <RepositoryUrl>https://github.com/sandre58/MyNet</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <RepositoryBranch>main</RepositoryBranch>

        <!-- Debug symbols configuration for better debugging experience -->
        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
        <DebugType>portable</DebugType>

        <!-- Symbols -->
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>

        <!-- SourceLink -->
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>

        <!-- Reproducible builds (CI only — avoids polluting local debug PDBs) -->
        <ContinuousIntegrationBuild Condition="'$(CI)' == 'true' Or '$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
        <Deterministic>true</Deterministic>
    </PropertyGroup>

    <!-- Embedded files -->
    <ItemGroup>
        <None Include="$(MSBuildThisFileDirectory)..\LICENSE" Pack="true" PackagePath="">
            <Link>_package/LICENSE</Link>
        </None>
        <None Include="$(MSBuildThisFileDirectory)..\assets\$(PackageIcon)" Pack="true" PackagePath="" Condition="Exists('$(MSBuildThisFileDirectory)..\assets\$(PackageIcon)')">
            <Link>_package/$(PackageIcon)</Link>
        </None>
    </ItemGroup>

    <!-- NuGet readme: icon at package root; repo readme uses ../../assets/ for GitHub -->
    <Target Name="_PreparePackageReadmeForPack"
            BeforeTargets="_GetPackageFiles"
            Condition="'$(IsPackable)' == 'true' And Exists('$(MSBuildProjectDirectory)\README.md')">
        <PropertyGroup>
            <PackageReadmePackPath>$(IntermediateOutputPath)README.md</PackageReadmePackPath>
            <_ReadmeSource>$([System.IO.File]::ReadAllText('$(MSBuildProjectDirectory)\README.md'))</_ReadmeSource>
            <_ReadmeForPack>$(_ReadmeSource.Replace('../../assets/', ''))</_ReadmeForPack>
        </PropertyGroup>
        <WriteLinesToFile File="$(PackageReadmePackPath)"
                          Lines="$(_ReadmeForPack)"
                          Overwrite="true"
                          Encoding="UTF-8" />
        <ItemGroup>
            <None Include="$(PackageReadmePackPath)" Pack="true" PackagePath="">
                <Link>_package/README.md</Link>
            </None>
        </ItemGroup>
    </Target>

</Project>
